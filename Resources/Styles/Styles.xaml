<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource AppAccent}, Dark={StaticResource AppAccent}}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource AppTextPrimary}, Dark={StaticResource AppTextPrimary}}" />
        <Setter Property="FontFamily" Value="OpenSansRegular"/>
    </Style>

    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource AppTextPrimary}" />
        <Setter Property="FontFamily" Value="OpenSansSemiBold"/>
        <Setter Property="CornerRadius" Value="10" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource AppTextPrimary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource AppElevated}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource AppBackground}" />
        <Setter Property="BarTextColor" Value="{StaticResource AppAccent}" />
    </Style>

    <Style TargetType="Shell">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource AppBackground}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource AppAccent}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource AppTextPrimary}" />
    </Style>

</ResourceDictionary>
